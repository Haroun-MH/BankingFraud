#!/usr/bin/env python3
"""
pre-commit — Git pre-commit hook: validate model accuracy before committing.

Installation
------------
Copy (or symlink) this file to .git/hooks/pre-commit and make it executable:

    copy hooks\\pre-commit .git\\hooks\\pre-commit
    # On Unix/macOS:
    cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

What it does
------------
1. Reads the active model run_id from reports/current_model.json.
2. Queries the MLflow tracking store for that run's val_accuracy metric.
3. If accuracy < ACCURACY_THRESHOLD (0.80), the commit is rejected.
4. If no model is registered yet, the commit is allowed with a warning.
"""
from __future__ import annotations

import json
import sys
from pathlib import Path

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
ACCURACY_THRESHOLD = 0.80

# ---------------------------------------------------------------------------
# Paths (resolved relative to the project root, two levels up from hooks/)
# ---------------------------------------------------------------------------
_HOOK_DIR = Path(__file__).resolve().parent
PROJECT_ROOT = _HOOK_DIR.parent
REPORTS_DIR = PROJECT_ROOT / "reports"
MLRUNS_DIR = PROJECT_ROOT / "mlruns"
REGISTRY_PATH = REPORTS_DIR / "current_model.json"


def _get_active_run_id() -> str | None:
    if not REGISTRY_PATH.exists():
        return None
    try:
        data = json.loads(REGISTRY_PATH.read_text(encoding="utf-8"))
        return data.get("run_id")
    except Exception:
        return None


def _get_run_accuracy(run_id: str) -> float | None:
    try:
        from mlflow.tracking import MlflowClient
        client = MlflowClient(tracking_uri=MLRUNS_DIR.as_uri())
        run = client.get_run(run_id)
        return run.data.metrics.get("val_accuracy")
    except Exception as exc:
        print(f"[pre-commit] WARNING: Could not read MLflow run {run_id}: {exc}")
        return None


def main() -> int:
    print("[pre-commit] Validating model accuracy...")

    run_id = _get_active_run_id()
    if not run_id:
        print("[pre-commit] No active model found in reports/current_model.json.")
        print("[pre-commit] Skipping accuracy check — commit allowed.")
        return 0

    accuracy = _get_run_accuracy(run_id)
    if accuracy is None:
        print(f"[pre-commit] Could not retrieve accuracy for run {run_id}.")
        print("[pre-commit] Skipping accuracy check — commit allowed.")
        return 0

    print(f"[pre-commit] Active model run: {run_id}")
    print(f"[pre-commit] val_accuracy = {accuracy:.4f}  (threshold = {ACCURACY_THRESHOLD})")

    if accuracy < ACCURACY_THRESHOLD:
        print(
            f"\n[pre-commit] COMMIT REJECTED: model accuracy {accuracy:.4f} "
            f"is below the required threshold of {ACCURACY_THRESHOLD}.\n"
            f"  Train a better model and set it as active before committing.\n"
        )
        return 1

    print(f"[pre-commit] Accuracy check passed. Commit allowed.\n")
    return 0


if __name__ == "__main__":
    sys.exit(main())
